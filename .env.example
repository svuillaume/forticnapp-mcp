# --- FortiCNAPP (Lacework) tenant ---
# Your account-specific API host, e.g. https://<account>.lacework.net
# Regional deployments use a suffix, e.g. https://<account>.fra.lacework.net (EU)
FORTICNAPP_API_BASE_URL=https://YourAccount.lacework.net

# Path to the OpenAPI spec bundled with this repo (YAML or JSON both load).
FORTICNAPP_OPENAPI_SPEC=./lw.yaml

# --- Credentials ---
# Created in the Lacework/FortiCNAPP console under Settings > API Keys.
# The console gives you a keyId and a secret; both are required.
FORTICNAPP_KEY_ID=
FORTICNAPP_API_SECRET=

# --- Auth strategy ---
# api_key_to_token (default, required for FortiCNAPP/Lacework): exchange
#   keyId+secret for a short-lived bearer token via FORTICNAPP_TOKEN_URL.
# api_key: send the secret directly on every request (no exchange step).
# bearer_static: use FORTICNAPP_API_SECRET verbatim as a pre-issued bearer token.
FORTICNAPP_AUTH_MODE=api_key_to_token

# Path (relative to FORTICNAPP_API_BASE_URL) or absolute URL for token exchange.
FORTICNAPP_TOKEN_URL=/api/v2/access/tokens
# Header used to carry the bearer token on normal API calls.
FORTICNAPP_TOKEN_HEADER_NAME=Authorization
# Header used to carry the raw secret on the token-exchange call itself
# (and on every call when FORTICNAPP_AUTH_MODE=api_key).
FORTICNAPP_API_KEY_HEADER_NAME=X-LW-UAKS
# Optional prefix placed before the secret value in FORTICNAPP_API_KEY_HEADER_NAME.
FORTICNAPP_API_KEY_PREFIX=
# Prefix placed before the token in FORTICNAPP_TOKEN_HEADER_NAME.
FORTICNAPP_BEARER_PREFIX=Bearer
# Requested lifetime (seconds) for exchanged tokens. FortiCNAPP caps this at 86400.
FORTICNAPP_TOKEN_EXPIRY_SECONDS=3600

# --- Tool surface ---
# Comma-separated OpenAPI tags to expose as MCP tools. The spec has 40 tags /
# 120 operations; this curated default keeps the tool list small enough for
# an LLM client to select from reliably. Widen it if you need more coverage.
FORTICNAPP_ENABLED_TAGS=Alerts,Entities,Vulnerabilities,VulnerabilityExceptions,Inventory,Policies,Reports,CloudAccounts,Events
# Expose non-idempotent operations (POST/PUT/PATCH/DELETE that aren't a
# .../search read) as tools. Off by default for safety.
ENABLE_MUTATION_TOOLS=false

# --- HTTP behaviour ---
REQUEST_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
# Cap on a single tool response body. Some endpoints (e.g. Inventory/search with a
# broad csp filter and no resourceType/returns narrowing) can return tens of MB in
# one response, which overflows MCP clients' stdio message-size guards and kills the
# whole server connection. Responses over this size are auto-chunked into multiple
# smaller tool calls (via pagination.next_page_url) instead of being returned raw --
# only responses that can't be chunked (not a list-shaped response, or a single row
# too large on its own) still fail with a "response_too_large" tool error.
MAX_RESPONSE_BYTES=5000000

# --- Logging ---
LOG_LEVEL=INFO

# --- HTTP transport (forticnapp-mcp-http / Docker only; unused for stdio) ---
# Shared secret HTTP clients must present as `Authorization: Bearer <token>`.
# Required to start forticnapp-mcp-http.
FORTICNAPP_MCP_HTTP_TOKEN=
FORTICNAPP_MCP_HTTP_HOST=0.0.0.0
FORTICNAPP_MCP_HTTP_PORT=8000
